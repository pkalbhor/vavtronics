# Deploy-time config for Cloud Functions (non-secret values only).
# The SMTP password is a secret — set it with:
#   firebase functions:secrets:set SMTP_PASS
#
# Pick the block matching your GoDaddy email type (defaults below are for
# classic GoDaddy Workspace / cPanel email):
#
#   GoDaddy Workspace email:   smtpout.secureserver.net  port 465  secure true
#   GoDaddy Professional (Titan): smtp.titan.email       port 465  secure true
#   GoDaddy Microsoft 365:     smtp.office365.com        port 587  secure false
#     (M365 also needs SMTP AUTH enabled for the mailbox, and an app
#      password if MFA is on)

SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@vavtronics.com
CONTACT_RECEIVER_EMAIL=info@vavtronics.com
